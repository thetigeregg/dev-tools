{
  "name": "@thetigeregg/dev-cli",
  "version": "0.4.3",
  "description": "Shared thetigeregg development CLI for worktree, env, and dependency workflows.",
  "type": "module",
  "bin": {
    "devx": "src/index.mjs"
  },
  "exports": {
    ".": "./src/api.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "templates",
    "README.md"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thetigeregg/dev-tools.git",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=20.17"
  },
  "keywords": [
    "cli",
    "devtools",
    "monorepo",
    "worktree"
  ],
  "scripts": {
    "test": "node --test test/*.test.mjs"
  }
}
