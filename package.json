{
  "name": "@thetigeregg/dev-tools",
  "private": true,
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=20.17"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "smoke": "node ./scripts/smoke-exports.mjs",
    "ci": "npm run test && npm run smoke",
    "format": "prettier . --check",
    "prepare": "husky",
    "deps:install-all": "devx deps install-all",
    "deps:ci-all": "devx deps ci-all",
    "deps:audit": "devx deps audit-all",
    "deps:ncu": "devx deps ncu-all",
    "repo:bootstrap": "devx repo bootstrap",
    "repo:sync": "devx repo sync",
    "repo:sync-templates": "devx repo sync-templates",
    "pr:summary": "devx pr summary",
    "pr:agent": "sh -c 'if [ \"$#\" -eq 0 ]; then echo \"Error: Missing PR number.\" >&2; echo \"Usage: npm run pr:agent -- <PR_NUMBER>\" >&2; exit 1; fi; devx pr agent \"$@\"' --",
    "commitlint": "commitlint --from=HEAD~1 --to=HEAD --verbose",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@thetigeregg/commitlint-config": "workspace:*",
    "@thetigeregg/dev-cli": "workspace:*",
    "@thetigeregg/lint-staged-config": "workspace:*",
    "@thetigeregg/ncu-config": "workspace:*",
    "@thetigeregg/prettier-config": "workspace:*",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "npm-check-updates": "^20.0.0",
    "prettier": "^3.8.1"
  }
}
